# Copy to .env and fill in. .env is gitignored.

# Anthropic API key — used by @anthropic-ai/claude-agent-sdk
ANTHROPIC_API_KEY=sk-ant-...

# GitHub fine-grained PAT for the sideprojects-aa account
# Scoped to: intrahealth-harness (single repo — harness + seed live together)
# Permissions: Contents R/W, Issues R/W, PRs R/W, Metadata R, Workflows R/W, Actions R/W
GH_PAT=github_pat_...

# GitHub repo coordinates the harness opens PRs against (this repo).
HARNESS_TARGET_OWNER=sideprojects-aa
HARNESS_TARGET_REPO=intrahealth-harness

# Optional: model overrides. Defaults to claude-sonnet-4-5 in code.
# Use claude-haiku-4-5 for cheap dev iteration; switch to sonnet/opus for golden runs.
HARNESS_MODEL=claude-haiku-4-5
