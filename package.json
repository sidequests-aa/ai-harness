{
  "name": "intrahealth-harness",
  "version": "0.1.0",
  "private": true,
  "description": "AI engineering harness — orchestration layer that takes a ticket, feeds it to coding agents with context, runs quality gates, and opens a PR.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "harness": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"context-packs/**/*.md\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@octokit/rest": "^21.0.0",
    "dotenv": "^16.4.5",
    "markdown-it": "^14.1.0",
    "picomatch": "^4.0.0",
    "ts-morph": "^24.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.5.0",
    "@types/picomatch": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
